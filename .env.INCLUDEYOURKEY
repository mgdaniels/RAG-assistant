# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# Real environment variables override anything set here.

# -----------------------------------------------------------------------------
# LLM provider — any OpenAI-compatible endpoint.
# Default is Google Gemini (free tier; create a key at https://aistudio.google.com).
# -----------------------------------------------------------------------------
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=yourAPIKey

# Local fallback with Ollama (no key, runs offline). To use it instead:
#   install Ollama, run `ollama pull llama3.1`, then swap in:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1
# LLM_API_KEY=ollama          # any non-empty string; Ollama ignores it

# -----------------------------------------------------------------------------
# Embeddings — local, no key required. Override only to try a different model.
# -----------------------------------------------------------------------------
# EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2